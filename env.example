# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1
APP_NAME=youruniverse-api

# ============================================
# Database (Supabase Postgres — or any Postgres)
# ============================================
# Supabase (Dashboard → Connect): use the connection pooler for DATABASE_URL (often port 6543, ?pgbouncer=true)
# and the "direct" / session URL for DIRECT_URL (port 5432) so Prisma migrations work.
# For local Postgres without a pooler, set DIRECT_URL to the same value as DATABASE_URL.

DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Single shared app user for open access (created on first POST /auth/login)
DEFAULT_USER_EMAIL=guest@localhost.local
DEFAULT_USER_USERNAME=guest
DEFAULT_USER_NAME=Guest

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# File Upload
# ============================================
UPLOAD_MAX_SIZE=10485760
# Max size for character/persona/lorebook import files in bytes (default 50MB = 52428800)
IMPORT_MAX_SIZE=52428800
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/gif
UPLOAD_DIR=./uploads

# ============================================
# Cloudinary (images — required for server-side image uploads)
# Dashboard: https://console.cloudinary.com/
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# ============================================
# CORS
# ============================================
# Single origin: CORS_ORIGIN=http://localhost:3000
# Multiple origins (comma-separated): CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
# Allow all origins in development: CORS_ORIGIN=*
# Note: ngrok URLs are automatically allowed in development mode
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ============================================
# Python Chat Microservice
# ============================================
PYTHON_CHAT_SERVICE_URL=http://localhost:8001

# Multiple AI models (Python chat service): JSON array of {"id","name","base_url","api_key"(optional),"model_name"(optional)}
# Example: [{"id":"claude-3","name":"Claude 3","base_url":"https://...","api_key":"..."},{"id":"llama-3","name":"Llama 3","base_url":"https://...","model_name":"meta/llama-3-70b"}]
# If empty, a single "default" model using OPENAI_* env vars is used.
CHAT_MODELS_JSON=

# ============================================
# AI Providers (OpenAI, Gemini, AWS)
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=8000
HOST=localhost
API_VERSION=v1
APP_NAME=youruniverse-api

# ============================================
# Database (PostgreSQL)
# ============================================


POSTGRES_USER=youruniverse
POSTGRES_PASSWORD=youruniverse_secret
POSTGRES_DB=youruniverse_db
DATABASE_URL=postgresql://youruniverse:youruniverse_secret@localhost:5432/youruniverse_db?schema=public

# ============================================
# Redis
# ============================================
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# ============================================
# JWT Tokens
# ============================================
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=amarjeet.boffinblocks@gmail.com
SMTP_PASS=qgql oqpr rwdh rcqw
SMTP_FROM=noreply@youruniverse.ai

# ============================================
# File Upload
# ============================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/gif
UPLOAD_DIR=./uploads

# ============================================
# AWS S3 (Optional - if not configured, files will be stored locally)
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_S3_ENDPOINT=  # Optional: For S3-compatible services (e.g., DigitalOcean Spaces)
AWS_S3_CDN_URL=  # Optional: CDN URL for public access (e.g., https://cdn.youruniverse.ai)

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# ============================================
# CORS
# ============================================
# Single origin: CORS_ORIGIN=http://localhost:3000
# Multiple origins (comma-separated): CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
# Allow all origins in development: CORS_ORIGIN=*
# Note: ngrok URLs are automatically allowed in development mode
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ============================================
# Python Chat Microservice
# ============================================
PYTHON_CHAT_SERVICE_URL=http://localhost:8001

# Multiple AI models (Python chat service): JSON array of {"id","name","base_url","api_key"(optional),"model_name"(optional)}
# Example: [{"id":"claude-3","name":"Claude 3","base_url":"https://...","api_key":"..."},{"id":"llama-3","name":"Llama 3","base_url":"https://...","model_name":"meta/llama-3-70b"}]
# If empty, a single "default" model using OPENAI_* env vars is used.
CHAT_MODELS_JSON=

# ============================================
# MFA / OTP
# ============================================
OTP_SECRET=your-otp-secret-key
OTP_ISSUER=youruniverse.ai


# ============================================
# AI Pipeline (Character chat enhancements)
# ============================================
# Preprocessing: intent/emotion detection (default: true)
# AI_PREPROCESSING_ENABLED=true
# Postprocessing: guardrail + humanizer (default: true)
# AI_POSTPROCESSING_ENABLED=true
# Comma-separated blocked words for safety (optional)
# AI_SAFETY_BLOCKED_WORDS=kill,bomb,suicide
# Comma-separated phrases to strip from responses (optional)
# AI_GUARDRAIL_BLOCKED_PHRASES=as an ai,language model,openai

# ============================================
# Mem0 Memory (Qdrant vector store)
# ============================================
# Set to "true" to enable persistent memory for chat
MEM0_ENABLED=true

# Qdrant - local Docker or cloud
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Optional: use full URL for Qdrant Cloud
# QDRANT_URL=https://xxx.qdrant.io
# QDRANT_API_KEY=your-qdrant-api-key

# Optional overrides
# MEM0_COLLECTION_NAME=youruniverse_memories
# MEM0_EMBEDDING_DIMS=1536

# Required for Mem0 embeddings (Gemini models/gemini-embedding-001)
GEMINI_API_KEY=your-gemini-api-key

# Optional: OpenAI for Mem0 LLM fact extraction (falls back to Gemini if not set)
# OPENAI_API_KEY=sk-your-openai-api-key

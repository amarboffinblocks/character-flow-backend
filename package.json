{
  "name": "youruniverse-backend",
  "version": "1.0.0",
  "description": "youruniverse.ai - Token-based AI platform backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "generate:routes": "node scripts/generate-route-registry.mjs",
    "prebuild": "npm run generate:routes",
    "predev": "npm run generate:routes",
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "vercel:build": "node scripts/generate-route-registry.mjs && prisma generate",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "ai",
    "characters",
    "chat",
    "personas",
    "lorebooks"
  ],
  "author": "youruniverse.ai",
  "license": "UNLICENSED",
  "dependencies": {
    "@ai-sdk/google": "^3.0.24",
    "@ai-sdk/openai": "^3.0.26",
    "@ai-sdk/openai-compatible": "^2.0.28",
    "@openai/agents": "^0.4.5",
    "@prisma/client": "^5.22.0",
    "@qdrant/js-client-rest": "^1.13.0",
    "@types/js-yaml": "^4.0.9",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "ai": "^6.0.79",
    "argon2": "^0.41.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "js-yaml": "^4.1.1",
    "mem0ai": "^2.2.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.8",
    "nodemailer": "^6.9.16",
    "openai": "^6.17.0",
    "otplib": "^12.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "png-chunks-extract": "^1.0.0",
    "prisma": "^5.22.0",
    "sharp": "^0.33.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.19.2",
    "uuid": "^10.0.0",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
